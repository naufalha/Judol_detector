# ============================================
# Judol Detector - Configuration
# ============================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# --- Pi-hole v6 Configuration ---
PIHOLE_URL=http://192.168.1.1
PIHOLE_PASSWORD=your_pihole_password_here

# --- DeepSeek API Configuration ---
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- Scan Configuration ---
# Scan interval in seconds (default: 60 = 1 minute)
SCAN_INTERVAL=60
# Maximum domains per batch sent to DeepSeek
BATCH_SIZE=100
# Number of recent queries to fetch from Pi-hole per scan
QUERY_LIMIT=1000

# --- Behavior ---
# Auto-block detected judol domains in Pi-hole (true/false)
AUTO_BLOCK=false
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Database path
DB_PATH=data/judol_history.db
# Reports directory
REPORTS_DIR=reports
